{
  "name": "@gwgs/lcq",
  "version": "0.2.1",
  "description": "A lightweight async task queue for JavaScript/TypeScript that limits the number of promises running concurrently.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wgsg/gwgs.git",
    "directory": "libs/lcq"
  },
  "author": {
    "name": "Chris Waters",
    "url": "https://www.npmjs.com/~crispwaters"
  },
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.esm.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "dependencies": {}
}
